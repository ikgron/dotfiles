# to save my git-delta settings

[core]
precomposeUnicode = true
symlinks = true
pager = delta

[interactive]
diffFilter = delta --color-only

[delta]
navigate = true
side-by-side = true
hyperlinks = true
wrap-max-lines = unlimited

[merge]
conflictStyle = zdiff3

# push easily. http://stackoverflow.com/a/23918418/89484
[push]
default = simple
followTags = true
autoSetupRemote = true

[pull]
ff = true
default = current

[protocol]
version = 2
